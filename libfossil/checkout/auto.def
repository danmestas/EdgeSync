# vim:se syn=tcl:
#
use wh-common cc cc-shared cc-lib
if {"--help" ne $::argv} {
  proj-tweak-default-env-dirs
}

set DUMP_DEFINES_FILE config.defines.txt
file delete -force $DUMP_DEFINES_FILE
options-add [subst [proj-strip-hash-comments {
  shared=1 => {Disable build of a shared library.}
  no-debug=0 => {Disable debug build options.}
  amal => {Generates a conservative config file for the amalgamation build.}
  static=1 => {Disable build of a static library.}
  profile=0 => {Enables the -pg (profiling) compile/link flag if CC is gcc.}
  no-fnc=0 => {Disable client/fnc build even if ncurses is found.}
  compile-commands=0 =>
    {Enable the check for compile_commands.json support,
    noting that it often detects a false positive. If CC is clang
    then it defaults to on instead of off.}
  c++=0  => {Enable the C++ bits. These fail to build on many clang systems for as-yet-unknown reasons.}
  ctags=0 => {Build ctags tag file, if available.}
  etags=0 => {Build etags tag file, if available.}
  assume-c99 => {Skip the check for C99 and _assume_ the compiler can handle C99 without the -std=c99 flag. This is a workaround for gcc 4.x.}
  ncurses=1 => {Disable ncurses pieces. Some platforms detect them and then can't build with it. Implies --no-fnc.}
  dump-defines=0  => {Write all configure-defined vars to $DUMP_DEFINES_FILE.}

  f-apps-link-lib-static=0 => {Link the f-apps statically to libfossil.}
  fnc-link-lib-static=0 => {Link fnc statically to libfossil.}
  apps-static=0
    => {As for --f-apps-link-lib-static and --fnc-link-lib-static, but also
      link the binaries statically. This may not work on all platforms,
      due to limitations of static linking in, e.g., glibc. Similarly, it
      only works if all dependent libraries are available in static form.}

  deps=1 => {Disable automatic dependencies generation.}
  pedantic=0 => {Enable pedantic build flags (may break with some imported upstream code)}
  soname:=none
          => {SONAME for libfossil.so. "none", or not using this flag, sets no
            soname. A value of "version" uses the library's package version. A
            value matching the glob "libfossil.*" sets it to that literal value.
            Any other value is assumed to be a suffix which gets applied to
            "libfossil.so.", e.g. --soname=9.10 equates to "libfossil.so.9.10".}
}]]
wh-handle-dll-basename -options
wh-handle-out-implib -options
wh-handle-with-sqlite -options
options {}

# autosetup interceps 'debug' and 'enable-debug' flags :/
#    prefix:=[get-env HOME /usr/local] -> "Installation prefix."

define FSL_PACKAGE_NAME "libfossil"
define FSL_LIBRARY_VERSION 0.6.0

########################################################################
# See if we can get the fossil schema version from the current
# checkout. If so, use that one, otherwise fall back to some
# hard-coded default. 2025-07-20: in all of libfossil's lifespan,
# these values have changed a single time. i.e. it's not really necessary
# to do this.
apply {{} {
  set auxSchema {}
  set contentSchema {}
  set fossilBin [proj-bin-define fossil]
  if {"" ne $fossilBin} {
    catch {
      set auxSchema [string trimright \
                       [exec "$fossilBin" sqlite3 {SELECT value FROM config WHERE name='aux-schema';}] ]
      set contentSchema [string trimright \
                           [exec "$fossilBin" sqlite3 {SELECT value FROM config WHERE name='content-schema';}] ]
    } ex
  }

  if {[string length $auxSchema] == 16} {
    msg-result "Got aux-schema value from current repo: $auxSchema"
    msg-result "Got content-schema value from current repo: $contentSchema"
  } else {
    set auxSchema "2015-01-24"
    set contentSchema 2
    msg-result "Using hard-coded aux-schema: $auxSchema"
    msg-result "Using hard-coded content-schema: $contentSchema"
  }
  define FSL_AUX_SCHEMA $auxSchema
  define FSL_CONTENT_SCHEMA $contentSchema
}}

########################################################################
# Grab the code version and timestamp from manifest.uuid and manifest
# files...
#
# This requires that the repo is NOT generating delta manifests. As
# of 2020-03, the libfossil server uses the forbid-delta-manifest
# setting.
apply {{} {
  set sd $::autosetup(srcdir)
  set ::timestamp [clock format [clock seconds] \
                   -gmt 1 -format "%Y-%m-%d %H:%M"]
  set ::libVersionHash [proj-file-content -trim "$sd/manifest.uuid"]

  set fp [open "$sd/manifest" rb]
  gets $fp line; # Skip C-card
  if {[string match "B *" $line]} {
    # Nope, that was a B-card. Try again.
    gets $fp line ; # Get C-card
  }
  gets $fp line ; # Get D-card
  close $fp
  set ::manifestTimestamp [string map {"D " "" T " "} $line]
}}
msg-result "libVersionHash = $libVersionHash"
msg-result "manifestTimestamp = $manifestTimestamp"

#
# Create VERSION.h, an intermediary file used by other pieces of the
# build process. This is not a distributable.
#
define VERSION_H ""
apply {{} {
  set ofile VERSION.h
  set out [open $ofile w]
  set vh [subst {#define FSL_PACKAGE_NAME "[get-define FSL_PACKAGE_NAME]"
#define FSL_LIBRARY_VERSION "[get-define FSL_LIBRARY_VERSION]"
#define FSL_LIB_VERSION_HASH "$::libVersionHash"
#define FSL_LIB_VERSION_TIMESTAMP "$::manifestTimestamp UTC"
#define FSL_LIB_CONFIG_TIMESTAMP "$::timestamp GMT"
#define FSL_AUX_SCHEMA "[get-define FSL_AUX_SCHEMA]"
#define FSL_CONTENT_SCHEMA "[get-define FSL_CONTENT_SCHEMA]"
#define FOSSIL_RELEASE_VERSION_NUMBER 22700
#define FOSSIL_MANIFEST_NUMERIC_DATE 20250727
#define FOSSIL_MANIFEST_NUMERIC_TIME 110738
}]
  puts $out $vh
  close $out
  define VERSION_H $vh
  msg-result "Created $ofile"
}}

if {[opt-bool amal]} {
  apply {{} {
    msg-result "Generating conservative config for the amalgamation build..."
    set incGuard _NET_FOSSIL_SCM_FSL_AMALGAMATION_CONFIG_H_INCLUDED_
    set ofile libfossil-config.h
    set out [open $ofile w]
    puts $out "#if !defined($incGuard)"
    puts $out "#define $incGuard 1"
    puts $out "/* Tweak the following for your system... */"
    set notOnWindows "<skipped>"
    foreach {def valUnix valWin} [subst -nocommands {
      HAVE_COMPRESS 1 1
      HAVE_STDINT_H 1 1
      HAVE_LSTAT 1 0
      HAVE_OPENDIR 1 1
      HAVE_PIPE 1 0
      HAVE_STAT 1 0
      _DEFAULT_SOURCE 1 $notOnWindows
      _XOPEN_SOURCE 700 $notOnWindows
      HAVE_CLOCK_GETTIME 1 0
    }] {
      if {$valUnix eq $valWin || $notOnWindows eq $valWin} {
        puts -nonewline $out [subst -nocommands \
{#if !defined($def)
#  define $def $valUnix
#endif
}]
      } else {
        puts -nonewline $out [subst -nocommands \
{#if defined(_WIN32)
#  if !defined($def)
#    define $def $valWin
#  endif
#else
#  if !defined($def)
#    define $def $valUnix
#  endif
#endif
}]
      }
    }
    puts $out "#endif /* $incGuard */"
    close $out
    msg-result "Generated $ofile"
  }}
  return; # leave the configure script!
}
# end of --amal bootstrap config generation
########################################################################

wh-require-bash; # for amalgamation generation (TODO: port that to tcl)
#cc-check-c11

if {![wh-cc-check-c99 0]} {
  if {[opt-bool assume-c99]} {
    proj-indented-notice {
      WARNING: the compiler claims to not support C99, but --assume-c99 was used,
      so ignoring that and continuing.
    }
  } else {
    user-error "As of 2021-02-21, libfossil requires C99 or higher."
  }
}

if {![wh-handle-with-sqlite extsrc]} {
  user-error "libsqlite3 not found. Use --with-sqlite=tree to use the built-in copy."
}

#
# --compile-commands must be checked relatively early or else flags
# added later, like -Werror, break it.
#
proj-check-compile-commands -assume-for-clang compile-commands

if {![proj-check-rpath]} {
  proj-warn "could not figure out how to add the rpath, so f-apps linking might not work"
}

cc-check-sizeof "void *"

cc-with {} {
  if {![cc-check-includes zlib.h] ||
      ![cc-check-function-in-lib compress z]} {
    user-error "Missing functional zlib"
  }

  if {[cc-check-function-in-lib iconv iconv]} {
    # Needed on Mac platforms for text conversions
    define LDFLAGS_ICONV [get-define lib_iconv]
    undefine lib_iconv
  } else {
    define LDFLAGS_ICONV ""
  }

  define LDFLAGS_clock_gettime ""
  define HAVE_CLOCK_GETTIME 0
  if {[cc-check-functions clock_gettime]} {
    define LDFLAGS_clock_gettime ""
  } elseif {[cc-check-functions-in-lib clock_gettime rt]} {
    define LDFLAGS_clock_gettime [get-define lib_clock_gettime]
  }
}; # cc-with

#
# Set up deps generation. Must also come early due to CFLAGS/LDFLAGS
# interference.
#
apply {{} {
  define F_CC_DOT_D ""
  define F_CXX_DOT_D ""
  if {![opt-bool deps]} {
    msg-result "C deps generation disabled."
    return
  }
  if {[wh-check-cc-deps-gen]} {
      define F_CC_DOT_D [join [list [get-define CC_DEPS_GEN_FLAG] \${@:.o=.d}]]
  }
  if {[opt-bool c++] && [wh-check-cc-deps-gen c++]} {
    define F_CXX_DOT_D [join [list [get-define CC_DEPS_GEN_FLAG] \${@:.o=.d}]]
  }
}}

cc-check-functions sigaction fork
#if {![cc-check-functions iconv] &&
#    ![cc-check-function-in-lib iconv iconv]} {
#    user-error "Cannot find iconv(3) in libc or libiconv"
#}

wh-check-pthread
proj-file-extensions

